{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Ensemble Transfer Schema",
  "description": "Transfer schema from modular workers to Arbiter (intermediate payload)",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version, e.g. 1.0.0"
    },
    "request_id": {
      "type": "string",
      "description": "Unique request identifier"
    },
    "original_query": {
      "type": "string",
      "description": "Original user query"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the request was processed"
    },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "worker_id": {
            "type": "string",
            "description": "Unique identifier of the worker/module"
          },
          "model": {
            "type": "string",
            "description": "Model name used by this worker"
          },
          "answer": {
            "type": "string",
            "description": "Raw answer generated by the worker"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence score between 0 and 1"
          }
        },
        "required": ["worker_id", "model", "answer", "confidence"]
      }
    }
  },
  "required": ["schema_version", "request_id", "original_query", "timestamp", "workers"],
  "additionalProperties": false
}